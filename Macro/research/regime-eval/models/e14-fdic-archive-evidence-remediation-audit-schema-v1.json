{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://macro-regime.local/schemas/e14-fdic-archive-evidence-remediation-audit-v1.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "artifactType", "status", "inputs", "checks", "validatorSelfTest", "protocol", "decision", "implementation"],
  "properties": {
    "schemaVersion": {"const": 1},
    "artifactType": {"const": "E14FdicArchiveEvidenceRemediationAudit"},
    "status": {"const": "FDIC_ARCHIVE_EVIDENCE_MODEL_REMEDIATED_INDEPENDENT_REVIEW_REQUIRED"},
    "inputs": {"$ref": "#/$defs/inputs"},
    "checks": {"$ref": "#/$defs/checks"},
    "validatorSelfTest": {"$ref": "#/$defs/selfTest"},
    "protocol": {"$ref": "#/$defs/protocol"},
    "decision": {"$ref": "#/$defs/decision"},
    "implementation": {"$ref": "#/$defs/implementation"}
  },
  "$defs": {
    "artifact": {"type": "object", "additionalProperties": false, "required": ["fileName", "sha256", "sizeBytes"], "properties": {"fileName": {"type": "string", "minLength": 1}, "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "sizeBytes": {"type": "integer", "minimum": 1}}},
    "inputs": {"type": "object", "additionalProperties": false, "required": ["contract", "blockedReview", "remediationPlan", "evidenceManifestSchema", "mapSchemaV3", "mapAuditSchemaV3", "remediationAuditSchema"], "properties": {"contract": {"$ref": "#/$defs/artifact"}, "blockedReview": {"$ref": "#/$defs/artifact"}, "remediationPlan": {"$ref": "#/$defs/artifact"}, "evidenceManifestSchema": {"$ref": "#/$defs/artifact"}, "mapSchemaV3": {"$ref": "#/$defs/artifact"}, "mapAuditSchemaV3": {"$ref": "#/$defs/artifact"}, "remediationAuditSchema": {"$ref": "#/$defs/artifact"}}},
    "checks": {"type": "object", "additionalProperties": false, "required": ["allInputHashesExact", "blockedReviewRequiresRemediation", "providerUrlAndRequestProvenanceRequired", "singleRosterModelDefined", "auditValidatorReportRequired", "partialPublicationBlockedByValidator", "catalogV3Absent", "snapshotV2Absent"], "properties": {"allInputHashesExact": {"const": true}, "blockedReviewRequiresRemediation": {"const": true}, "providerUrlAndRequestProvenanceRequired": {"const": true}, "singleRosterModelDefined": {"const": true}, "auditValidatorReportRequired": {"const": true}, "partialPublicationBlockedByValidator": {"const": true}, "catalogV3Absent": {"const": true}, "snapshotV2Absent": {"const": true}}},
    "selfTest": {"type": "object", "additionalProperties": false, "required": ["validFixtureAccepted", "partialRosterRejected", "duplicateQuarterRejected", "provenanceMismatchRejected", "outcomeMismatchRejected", "scenariosPassed"], "properties": {"validFixtureAccepted": {"const": true}, "partialRosterRejected": {"const": true}, "duplicateQuarterRejected": {"const": true}, "provenanceMismatchRejected": {"const": true}, "outcomeMismatchRejected": {"const": true}, "scenariosPassed": {"const": 5}}},
    "protocol": {"type": "object", "additionalProperties": false, "required": ["networkRequestsMade", "discoveryCatalogsMaterialized", "evidenceRowsCollected", "rawArtifactsWritten", "mapV3Materialized", "evaluationPerformed", "outerOosRead"], "properties": {"networkRequestsMade": {"const": 0}, "discoveryCatalogsMaterialized": {"const": 0}, "evidenceRowsCollected": {"const": 0}, "rawArtifactsWritten": {"const": 0}, "mapV3Materialized": {"const": false}, "evaluationPerformed": {"const": false}, "outerOosRead": {"const": false}}},
    "decision": {"type": "object", "additionalProperties": false, "required": ["evidenceModelRemediated", "semanticValidatorImplemented", "independentReviewAuthorized", "discoveryCatalogAuthorized", "executionGateAuthorized", "requestCatalogV3MaterializationAuthorized", "sourceAcquisitionAuthorized", "nextAllowedAction"], "properties": {"evidenceModelRemediated": {"const": true}, "semanticValidatorImplemented": {"const": true}, "independentReviewAuthorized": {"const": true}, "discoveryCatalogAuthorized": {"const": false}, "executionGateAuthorized": {"const": false}, "requestCatalogV3MaterializationAuthorized": {"const": false}, "sourceAcquisitionAuthorized": {"const": false}, "nextAllowedAction": {"type": "string", "minLength": 20}}},
    "implementation": {"type": "object", "additionalProperties": false, "required": ["module", "sourceSha256"], "properties": {"module": {"const": "regime_eval.e14_fdic_archive_evidence_remediation"}, "sourceSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}}}
  }
}
