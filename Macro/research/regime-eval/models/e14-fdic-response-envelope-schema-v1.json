{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://macro-regime.local/schemas/e14-fdic-response-envelope-v1.json",
  "type": "object", "additionalProperties": false,
  "required": ["schemaVersion", "envelopeId", "collectorId", "requestId", "quarterId", "requestedUrl", "finalUrl", "redirects", "retrievedAtUtc", "statusCode", "contentType", "outcome", "responseBodyBase64", "responseSha256", "responseSizeBytes", "signatureBase64"],
  "properties": {
    "schemaVersion": {"const": 1},
    "envelopeId": {"type": "string", "minLength": 3},
    "collectorId": {"type": "string", "minLength": 3},
    "requestId": {"type": "string", "minLength": 3},
    "quarterId": {"type": "string", "pattern": "^20[0-9]{2}Q[1-4]$"},
    "requestedUrl": {"type": "string", "pattern": "^https://archive\\.fdic\\.gov/.*$"},
    "finalUrl": {"type": "string", "pattern": "^https://archive\\.fdic\\.gov/.*$"},
    "redirects": {"type": "array", "maxItems": 8, "items": {"type": "object", "additionalProperties": false, "required": ["statusCode", "fromUrl", "location", "toUrl"], "properties": {"statusCode": {"type": "integer", "minimum": 300, "maximum": 399}, "fromUrl": {"type": "string"}, "location": {"type": "string"}, "toUrl": {"type": "string"}}}},
    "retrievedAtUtc": {"type": "string", "minLength": 20},
    "statusCode": {"type": "integer", "minimum": 200, "maximum": 499},
    "contentType": {"type": "string", "minLength": 3},
    "outcome": {"enum": ["resolved-provider-archive-record", "confirmed-absent-provider-primary"]},
    "responseBodyBase64": {"type": "string", "minLength": 4},
    "responseSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "responseSizeBytes": {"type": "integer", "minimum": 1},
    "signatureBase64": {"type": "string", "minLength": 80}
  }
}
