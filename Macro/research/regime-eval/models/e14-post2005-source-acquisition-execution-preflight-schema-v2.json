{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://macro-regime.local/schemas/e14-post2005-source-acquisition-execution-preflight-audit-v2.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "artifactType", "status", "executedAtUtc", "inputs", "inventory", "discoveryResults", "blockers", "checks", "protocol", "decision", "implementation"],
  "properties": {
    "schemaVersion": {"const": 2},
    "artifactType": {"const": "E14Post2005SourceAcquisitionExecutionPreflightAudit"},
    "status": {"enum": ["POST_2005_SOURCE_V2_ACQUISITION_DISCOVERY_READY", "POST_2005_SOURCE_V2_ACQUISITION_BLOCKED_DISCOVERY_CATALOG_REMEDIATION_REQUIRED"]},
    "executedAtUtc": {"type": "string", "minLength": 20},
    "inputs": {"$ref": "#/$defs/inputs"},
    "inventory": {"$ref": "#/$defs/inventory"},
    "discoveryResults": {"type": "array", "minItems": 3, "maxItems": 3, "items": {"$ref": "#/$defs/discovery"}},
    "blockers": {"type": "array", "items": {"$ref": "#/$defs/blocker"}},
    "checks": {"$ref": "#/$defs/checks"},
    "protocol": {"$ref": "#/$defs/protocol"},
    "decision": {"$ref": "#/$defs/decision"},
    "implementation": {"$ref": "#/$defs/implementation"}
  },
  "$defs": {
    "artifact": {"type": "object", "additionalProperties": false, "required": ["fileName", "sha256", "sizeBytes"], "properties": {"fileName": {"type": "string"}, "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "sizeBytes": {"type": "integer", "minimum": 1}}},
    "inputs": {"type": "object", "additionalProperties": false, "required": ["executionContractV2", "sourceAcquisitionManifestV2", "requestCatalogV2", "sourceExecutionGateAuditV3", "executionPlanV2", "preflightSchemaV2"], "properties": {"executionContractV2": {"$ref": "#/$defs/artifact"}, "sourceAcquisitionManifestV2": {"$ref": "#/$defs/artifact"}, "requestCatalogV2": {"$ref": "#/$defs/artifact"}, "sourceExecutionGateAuditV3": {"$ref": "#/$defs/artifact"}, "executionPlanV2": {"$ref": "#/$defs/artifact"}, "preflightSchemaV2": {"$ref": "#/$defs/artifact"}}},
    "inventory": {"type": "object", "additionalProperties": false, "required": ["discoveryRequestCount", "successfulDiscoveryRequestCount", "blockerCount", "h8DirectReleaseDateCount", "fdicEligibleDocumentCount", "fdicActualPublicationProofCount", "g5ReleaseCount", "g5UniqueMonthCount", "g5DuplicateMonthCount"], "properties": {"discoveryRequestCount": {"const": 3}, "successfulDiscoveryRequestCount": {"type": "integer", "minimum": 0, "maximum": 3}, "blockerCount": {"type": "integer", "minimum": 0}, "h8DirectReleaseDateCount": {"type": "integer", "minimum": 0}, "fdicEligibleDocumentCount": {"type": "integer", "minimum": 0}, "fdicActualPublicationProofCount": {"type": "integer", "minimum": 0}, "g5ReleaseCount": {"type": "integer", "minimum": 0}, "g5UniqueMonthCount": {"type": "integer", "minimum": 0}, "g5DuplicateMonthCount": {"type": "integer", "minimum": 0}}},
    "discovery": {"type": "object", "additionalProperties": false, "required": ["requestId", "sourceId", "urlTemplate", "statusCode", "finalHost", "redirectChainHosts", "contentType", "sizeBytes", "sha256", "payloadPersisted"], "properties": {"requestId": {"enum": ["h8-release-index-v2", "fdic-qbp-publication-index-v2", "g5-release-calendar-v2"]}, "sourceId": {"enum": ["federal-reserve-h8-release-archive", "fdic-qbp-archive", "federal-reserve-g5-release-archive"]}, "urlTemplate": {"enum": ["https://www.federalreserve.gov/releases/h8/default.htm", "https://www.fdic.gov/analysis/quarterly-banking-profile/", "https://www.federalreserve.gov/releases/g5/releaseDates.json"]}, "statusCode": {"const": 200}, "finalHost": {"enum": ["www.federalreserve.gov", "www.fdic.gov"]}, "redirectChainHosts": {"type": "array", "minItems": 1, "items": {"enum": ["www.federalreserve.gov", "www.fdic.gov"]}}, "contentType": {"type": ["string", "null"]}, "sizeBytes": {"type": "integer", "minimum": 1}, "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "payloadPersisted": {"const": false}}},
    "blocker": {"type": "object", "additionalProperties": false, "required": ["code", "sourceId", "requestId", "observed", "required", "remediation"], "properties": {"code": {"type": "string"}, "sourceId": {"type": "string"}, "requestId": {"type": "string"}, "observed": {}, "required": {}, "remediation": {"type": "string"}}},
    "checks": {"type": "object", "additionalProperties": false, "required": ["allInputHashesExact", "gateAuthorizedExactManifestAndCatalog", "onlyPreregisteredDiscoveryUrlsRequested", "allRedirectsOnAllowlist", "rawPayloadsDiscarded", "snapshotAbsent", "stagingAbsent", "secretValuesAbsent", "eventTimeAndFredRequestsNotStarted"], "properties": {"allInputHashesExact": {"const": true}, "gateAuthorizedExactManifestAndCatalog": {"const": true}, "onlyPreregisteredDiscoveryUrlsRequested": {"const": true}, "allRedirectsOnAllowlist": {"const": true}, "rawPayloadsDiscarded": {"const": true}, "snapshotAbsent": {"const": true}, "stagingAbsent": {"const": true}, "secretValuesAbsent": {"const": true}, "eventTimeAndFredRequestsNotStarted": {"const": true}}},
    "protocol": {"type": "object", "additionalProperties": false, "required": ["networkRequestsMade", "discoveryRequestsMade", "eventTimeRequestsMade", "fredRequestsMade", "rawArtifactsPublished", "observationsAcquired", "featuresTransformed", "candidatesGenerated", "evaluationPerformed", "outerOosRead"], "properties": {"networkRequestsMade": {"type": "integer", "minimum": 0, "maximum": 3}, "discoveryRequestsMade": {"type": "integer", "minimum": 0, "maximum": 3}, "eventTimeRequestsMade": {"const": 0}, "fredRequestsMade": {"const": 0}, "rawArtifactsPublished": {"const": 0}, "observationsAcquired": {"const": 0}, "featuresTransformed": {"const": 0}, "candidatesGenerated": {"const": 0}, "evaluationPerformed": {"const": false}, "outerOosRead": {"const": false}}},
    "decision": {"type": "object", "additionalProperties": false, "required": ["fullAtomicAcquisitionAuthorized", "featureTransformationAuthorized", "candidateGenerationAuthorized", "evaluationAuthorized", "outerOosAuthorized", "nextAllowedAction"], "properties": {"fullAtomicAcquisitionAuthorized": {"type": "boolean"}, "featureTransformationAuthorized": {"const": false}, "candidateGenerationAuthorized": {"const": false}, "evaluationAuthorized": {"const": false}, "outerOosAuthorized": {"const": false}, "nextAllowedAction": {"type": "string"}}},
    "implementation": {"type": "object", "additionalProperties": false, "required": ["module", "sourceSha256"], "properties": {"module": {"const": "regime_eval.e14_post2005_source_acquisition_execution_v2"}, "sourceSha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}}
  }
}
