{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://macro-regime.local/schemas/e14-fdic-archive-atomic-producer-v5-audit-v1.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "artifactType", "status", "hashes", "checks", "testExecution", "platformQualification", "protocol", "decision"],
  "properties": {
    "schemaVersion": {"const": 1},
    "artifactType": {"const": "E14FdicArchiveAtomicProducerV5Audit"},
    "status": {"const": "FDIC_ARCHIVE_ATOMIC_PRODUCER_V5_IMPLEMENTED_INDEPENDENT_REVIEW_REQUIRED"},
    "hashes": {
      "type": "object", "additionalProperties": false,
      "required": ["implementationContract", "blockedReview", "plan", "contractVerifier", "producer", "testRunnerTrust", "testRunner", "platformQualification", "tests", "collectorReceiptSchema", "ledgerSchema", "bundleAuditSchema", "runtimeTestContract", "projectConfiguration"],
      "properties": {
        "implementationContract": {"$ref": "#/$defs/sha"}, "blockedReview": {"$ref": "#/$defs/sha"}, "plan": {"$ref": "#/$defs/sha"}, "contractVerifier": {"$ref": "#/$defs/sha"}, "producer": {"$ref": "#/$defs/sha"}, "testRunnerTrust": {"$ref": "#/$defs/sha"}, "testRunner": {"$ref": "#/$defs/sha"}, "platformQualification": {"$ref": "#/$defs/sha"}, "tests": {"$ref": "#/$defs/sha"}, "collectorReceiptSchema": {"$ref": "#/$defs/sha"}, "ledgerSchema": {"$ref": "#/$defs/sha"}, "bundleAuditSchema": {"$ref": "#/$defs/sha"}, "runtimeTestContract": {"$ref": "#/$defs/sha"}, "projectConfiguration": {"$ref": "#/$defs/sha"}
      }
    },
    "checks": {
      "type": "object", "additionalProperties": false,
      "required": ["testRunnerKeyPinnedOutsideReceipt", "receiptChainHeadEnforced", "exactReplayRejected", "nonceConsumedBeforePublication", "strictNestedHashRosters", "providerNetworkCaptureRejected", "completeStagingRevalidation"],
      "properties": {"testRunnerKeyPinnedOutsideReceipt": {"const": true}, "receiptChainHeadEnforced": {"const": true}, "exactReplayRejected": {"const": true}, "nonceConsumedBeforePublication": {"const": true}, "strictNestedHashRosters": {"const": true}, "providerNetworkCaptureRejected": {"const": true}, "completeStagingRevalidation": {"const": true}}
    },
    "testExecution": {
      "type": "object", "additionalProperties": false, "required": ["receiptSha256", "transcriptSha256", "signerId", "externallyPinnedKeyVerified", "passed", "testsRun"],
      "properties": {"receiptSha256": {"$ref": "#/$defs/sha"}, "transcriptSha256": {"$ref": "#/$defs/sha"}, "signerId": {"const": "e14-v5-synthetic-test-runner-v1"}, "externallyPinnedKeyVerified": {"const": true}, "passed": {"const": true}, "testsRun": {"const": 8}}
    },
    "platformQualification": {
      "type": "object", "additionalProperties": false, "required": ["platform", "qualificationMode", "failClosedOnIdentityChange"],
      "properties": {"platform": {"type": "string", "minLength": 3}, "qualificationMode": {"enum": ["native-o-nofollow-plus-descriptor-identity", "descriptor-identity-fallback"]}, "failClosedOnIdentityChange": {"const": true}}
    },
    "protocol": {
      "type": "object", "additionalProperties": false, "required": ["networkRequestsMade", "realEvidenceRowsCollected", "realBundlesPublished", "productionContractsPinned"],
      "properties": {"networkRequestsMade": {"const": 0}, "realEvidenceRowsCollected": {"const": 0}, "realBundlesPublished": {"const": 0}, "productionContractsPinned": {"const": 0}}
    },
    "decision": {
      "type": "object", "additionalProperties": false, "required": ["independentReviewAuthorized", "discoveryCatalogAuthorized", "executionGateAuthorized", "sourceAcquisitionAuthorized", "nextAllowedAction"],
      "properties": {"independentReviewAuthorized": {"const": true}, "discoveryCatalogAuthorized": {"const": false}, "executionGateAuthorized": {"const": false}, "sourceAcquisitionAuthorized": {"const": false}, "nextAllowedAction": {"type": "string", "minLength": 20}}
    }
  },
  "$defs": {"sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"}}
}
