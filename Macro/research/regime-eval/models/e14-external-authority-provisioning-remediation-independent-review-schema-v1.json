    }},
    "assessments": {"const": {"hashBindingsExact":true,"blockedReviewNeedsChangesBound":true,"schemasClosed":true,"operationalProtocolExact":true,"allTenEvidenceClassesIndividuallyRequired":true,"evidenceClassOmissionRejected":true,"stateMachineFrozen":true,"readOperationSpecified":true,"casPendingSpecified":true,"commitSpecified":true,"recoverSpecified":true,"monotonicVersionSemanticsSpecified":true,"authenticatedReceiptChainSpecified":true,"identityAndRolesSpecified":true,"leastPrivilegeSpecified":true,"idempotencySemanticsSpecified":true,"errorAndRetryModelSpecified":true,"pendingCrashRecoverySpecified":true,"postRenameRecoverySpecified":true,"rollbackPreventionSpecified":true,"crossVolumePreflightSpecified":true,"directoryDurabilitySpecified":true,"descriptorNoFollowSpecified":true,"processStartLockIdentitySpecified":true,"mandatoryConformanceTestCount":14,"mandatoryConformanceMatrixNonOmissible":true,"providerNeutral":true,"providerSelected":false,"credentialsCreated":false,"remoteResourcesCreated":false,"adapterImplemented":false,"networkRequestsMade":0,"productionRegistryEmpty":true,"producerV7UnconditionallyBlocked":true,"publicationAuthorized":false,"downstreamAuthorized":false,"designCompleteSafelyBlocked":true}},
    "decision": {"const": "accept"}, "blockingFindings": {"type": "array", "maxItems": 0},
