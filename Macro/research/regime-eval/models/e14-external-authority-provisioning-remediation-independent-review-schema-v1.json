  "$defs": {"sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "finding": {"type": "object", "additionalProperties": false, "required": ["severity", "code", "evidence"], "properties": {"severity": {"enum": ["low", "medium", "high", "critical"]}, "code": {"type": "string", "minLength": 3}, "evidence": {"type": "string", "minLength": 20}}}}
