{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://macro-regime.local/schemas/e14-post2005-source-execution-gate-audit-v1.json",
  "title": "E14 post-2005 source acquisition execution gate audit",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "artifactType", "status", "executedAtUtc", "inputs", "inventory", "credentialResults", "probeResults", "checks", "protocol", "decision", "implementation"],
  "properties": {
    "schemaVersion": {"const": 1},
    "artifactType": {"const": "E14Post2005SourceAcquisitionExecutionGateAudit"},
    "status": {"enum": ["POST_2005_SOURCE_ACQUISITION_EXECUTION_AUTHORIZED", "POST_2005_SOURCE_ACQUISITION_EXECUTION_BLOCKED"]},
    "executedAtUtc": {"type": "string", "minLength": 20},
    "inputs": {"type": "object"},
    "inventory": {"type": "object"},
    "credentialResults": {"type": "array", "minItems": 1},
    "probeResults": {"type": "array", "minItems": 7, "maxItems": 7},
    "checks": {"type": "object"},
    "protocol": {"type": "object"},
    "decision": {"type": "object"},
    "implementation": {"type": "object"}
  }
}
