{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://macro-regime.local/schemas/e14-mechanism-feature-foundation-v1.json",
  "title": "E14 mechanism feature foundation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "artifactType",
    "foundationId",
    "status",
    "cutoffDate",
    "taxonomy",
    "rawSnapshots",
    "series",
    "detectorBindings",
    "missingnessPolicy",
    "limitations"
  ],
  "properties": {
    "schemaVersion": {"const": 1},
    "artifactType": {"const": "E14MechanismFeatureFoundation"},
    "foundationId": {"const": "e14-mechanism-feature-foundation-v1"},
    "status": {"const": "materialized-with-vintage-limitations"},
    "cutoffDate": {"const": "2025-12-31"},
    "taxonomy": {"type": "object"},
    "rawSnapshots": {"type": "array", "minItems": 5, "maxItems": 5},
    "series": {"type": "array", "minItems": 5, "maxItems": 5},
    "detectorBindings": {"type": "array", "minItems": 6, "maxItems": 6},
    "missingnessPolicy": {"type": "object"},
    "limitations": {"type": "array", "minItems": 1}
  }
}
