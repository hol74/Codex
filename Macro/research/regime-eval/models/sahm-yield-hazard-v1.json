{
  "schemaVersion": 1,
  "modelId": "sahm-yield-hazard-v1",
  "modelFamily": "Causal rule-based recession hazard with labor, production and yield-curve transition",
  "taskRole": "recession-signal",
  "lifecycleStatus": "research-challenger",
  "promotionTarget": "shadow-candidate",
  "frozenAt": "2026-07-14",
  "benchmarkScope": "nested-inner-validation-only",
  "inputs": ["SAHM", "INDPRO_YOY", "YC_10Y2Y"],
  "transforms": {
    "sahmSeverity": "clip01(SAHM / 0.50)",
    "growthDeterioration": "clip01((1.0 - INDPRO_YOY) / 7.0)",
    "curveInversion": "clip01(-minimum(YC_10Y2Y over current and prior 23 observations) / 0.75)",
    "curveResteepening": "clip01((current YC_10Y2Y - trailing minimum) / 1.0)",
    "curveTransition": "curveInversion * curveResteepening"
  },
  "hazardScore": "0.50 * sahmSeverity + 0.30 * growthDeterioration + 0.20 * curveTransition",
  "probability": "sigmoid(8 * (hazardScore - 0.50))",
  "decisionThreshold": 0.5,
  "statePolicy": "stateless monthly hazard; no backward smoothing, no future persistence and no label-fitted duration",
  "labelPolicy": "Predictions are frozen before NBER labels are attached. NBER chronology is used only for inner gate metrics.",
  "outerOosPolicy": "Forbidden for selection, ranking, tuning or gate execution.",
