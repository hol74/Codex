{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://macro-regime.local/schemas/e14-post2005-source-acquisition-preregistration-audit-v2.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "artifactType", "status", "inputs", "outputs", "inventory", "checks", "protocol", "decision", "implementation"],
  "properties": {
    "schemaVersion": {"const": 2},
    "artifactType": {"const": "E14Post2005SourceAcquisitionPreregistrationAudit"},
    "status": {"const": "POST_2005_SOURCE_MANIFEST_V2_AND_REQUEST_CATALOG_V2_PREREGISTERED_EXECUTION_GATE_REQUIRED"},
    "inputs": {"type": "object", "additionalProperties": false, "required": ["acquisitionContractV2", "activeSourceVintagePolicyV2", "policyActivationAudit", "baseActiveTaxonomy", "scopeActivationAudit", "legacySourceManifestV1", "sourceAcquisitionEvidenceV2", "sourceAcquisitionPlanV2", "manifestSchemaV2", "requestCatalogSchemaV2", "preregistrationAuditSchemaV2"], "properties": {"acquisitionContractV2": {"$ref": "#/$defs/artifact"}, "activeSourceVintagePolicyV2": {"$ref": "#/$defs/artifact"}, "policyActivationAudit": {"$ref": "#/$defs/artifact"}, "baseActiveTaxonomy": {"$ref": "#/$defs/artifact"}, "scopeActivationAudit": {"$ref": "#/$defs/artifact"}, "legacySourceManifestV1": {"$ref": "#/$defs/artifact"}, "sourceAcquisitionEvidenceV2": {"$ref": "#/$defs/artifact"}, "sourceAcquisitionPlanV2": {"$ref": "#/$defs/artifact"}, "manifestSchemaV2": {"$ref": "#/$defs/artifact"}, "requestCatalogSchemaV2": {"$ref": "#/$defs/artifact"}, "preregistrationAuditSchemaV2": {"$ref": "#/$defs/artifact"}}},
    "outputs": {"type": "object", "additionalProperties": false, "required": ["sourceAcquisitionManifestV2", "requestCatalogV2"], "properties": {"sourceAcquisitionManifestV2": {"$ref": "#/$defs/artifact"}, "requestCatalogV2": {"$ref": "#/$defs/artifact"}}},
    "inventory": {"type": "object", "additionalProperties": false, "required": ["sourceCount", "featureFamilyCount", "requestTemplateCount", "retiredH10ReferenceCount", "providerPrimaryLocatorCount"], "properties": {"sourceCount": {"const": 7}, "featureFamilyCount": {"const": 4}, "requestTemplateCount": {"const": 11}, "retiredH10ReferenceCount": {"const": 0}, "providerPrimaryLocatorCount": {"type": "integer", "minimum": 15}}},
    "checks": {"type": "object", "additionalProperties": false, "required": ["allInputHashesExact", "activePolicyV2Exact", "baseTaxonomyAndLabelsUnchanged", "legacyManifestV1Unchanged", "exactSevenSourceRoster", "h10AbsentFromManifestCatalogAndRawPaths", "g5ReplacesH10", "g5MethodologyRegimesFrozen", "g5UniqueMonthCoverageRequirementFrozen", "fdicActualPublicationProofFrozen", "fdicEligibleQuarterBoundaryFrozen", "allSourcesMetadataReady", "outputsSchemaClosed", "networkRequestsAbsent"], "properties": {"allInputHashesExact": {"const": true}, "activePolicyV2Exact": {"const": true}, "baseTaxonomyAndLabelsUnchanged": {"const": true}, "legacyManifestV1Unchanged": {"const": true}, "exactSevenSourceRoster": {"const": true}, "h10AbsentFromManifestCatalogAndRawPaths": {"const": true}, "g5ReplacesH10": {"const": true}, "g5MethodologyRegimesFrozen": {"const": true}, "g5UniqueMonthCoverageRequirementFrozen": {"const": true}, "fdicActualPublicationProofFrozen": {"const": true}, "fdicEligibleQuarterBoundaryFrozen": {"const": true}, "allSourcesMetadataReady": {"const": true}, "outputsSchemaClosed": {"const": true}, "networkRequestsAbsent": {"const": true}}},
    "protocol": {"type": "object", "additionalProperties": false, "required": ["manifestFrozen", "requestCatalogFrozen", "networkRequestsMade", "observationsAcquired", "rawArtifactsWritten", "featuresTransformed", "candidatesGenerated", "evaluationPerformed", "outerOosRead"], "properties": {"manifestFrozen": {"const": true}, "requestCatalogFrozen": {"const": true}, "networkRequestsMade": {"const": 0}, "observationsAcquired": {"const": 0}, "rawArtifactsWritten": {"const": 0}, "featuresTransformed": {"const": 0}, "candidatesGenerated": {"const": 0}, "evaluationPerformed": {"const": false}, "outerOosRead": {"const": false}}},
    "decision": {"type": "object", "additionalProperties": false, "required": ["manifestAndRequestCatalogReady", "separateExecutionGateAuthorized", "sourceAcquisitionExecutionAuthorized", "featureTransformationAuthorized", "candidateGenerationAuthorized", "evaluationAuthorized", "outerOosAuthorized", "nextAllowedAction"], "properties": {"manifestAndRequestCatalogReady": {"const": true}, "separateExecutionGateAuthorized": {"const": true}, "sourceAcquisitionExecutionAuthorized": {"const": false}, "featureTransformationAuthorized": {"const": false}, "candidateGenerationAuthorized": {"const": false}, "evaluationAuthorized": {"const": false}, "outerOosAuthorized": {"const": false}, "nextAllowedAction": {"const": "Run a separate fail-closed metadata execution gate against manifest v2 and request catalog v2; do not acquire observations yet"}}},
    "implementation": {"type": "object", "additionalProperties": false, "required": ["module", "sourceSha256"], "properties": {"module": {"const": "regime_eval.e14_post2005_source_acquisition_v2"}, "sourceSha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}}
  },
  "$defs": {"artifact": {"type": "object", "additionalProperties": false, "required": ["fileName", "sha256", "sizeBytes"], "properties": {"fileName": {"type": "string"}, "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "sizeBytes": {"type": "integer", "minimum": 1}}}}
}
