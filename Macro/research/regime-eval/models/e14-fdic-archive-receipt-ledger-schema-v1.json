{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://macro-regime.local/schemas/e14-fdic-archive-receipt-ledger-v1.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "artifactType", "headReceiptSha256", "entries"],
  "properties": {
    "schemaVersion": {"const": 1},
    "artifactType": {"const": "E14FdicArchiveReceiptLedger"},
    "headReceiptSha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["acquisitionRunId", "runNonce", "receiptSha256", "previousReceiptSha256", "targetPathSha256"],
        "properties": {
          "acquisitionRunId": {"type": "string", "minLength": 16},
          "runNonce": {"type": "string", "minLength": 24},
          "receiptSha256": {"$ref": "#/$defs/sha"},
          "previousReceiptSha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
          "targetPathSha256": {"$ref": "#/$defs/sha"}
        }
      }
    }
  },
  "$defs": {"sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"}}
}
