        "endpointReachable": {"const": false}, "adapterImplemented": {"const": false}, "failureModesPassed": {"const": false},
        "externalProvisioningAuthorized": {"const": false}, "providerNetworkAuthorized": {"const": false}, "productionPublicationAuthorized": {"const": false},
        "discoveryCatalogAuthorized": {"const": false}, "executionGateAuthorized": {"const": false}, "sourceAcquisitionAuthorized": {"const": false},
        "downstreamAuthorized": {"const": false}
      }
