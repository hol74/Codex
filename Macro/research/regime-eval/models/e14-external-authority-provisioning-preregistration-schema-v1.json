      "properties": {
        "externalToCopyableWorkspace": {"const": true}, "deploymentIdentityBound": {"const": true}, "immutableDeploymentPin": {"const": true},
        "closedContractValidation": {"const": true}, "mutualAuthentication": {"const": true}, "leastPrivilege": {"const": true},
        "authenticatedCompareAndSwap": {"const": true}, "crossDeploymentMonotonicity": {"const": true}, "coordinatedRollbackPrevention": {"const": true},
        "idempotentOperations": {"const": true}, "readAfterWriteVerification": {"const": true}, "pendingCommittedRecovery": {"const": true},
        "postRenameRecovery": {"const": true}, "crossVolumePreflight": {"const": true}, "directoryDurability": {"const": true},
        "descriptorNoFollowReads": {"const": true}, "processStartLockIdentity": {"const": true}, "tamperEvidentReceipts": {"const": true}
      }
    },
    "requiredProvisioningEvidence": {
      "type": "array", "minItems": 8, "uniqueItems": true,
      "items": {"enum": ["provider-identity", "endpoint-identity", "certificate-or-key-fingerprints", "tenant-and-deployment-binding", "access-policy", "retention-and-rollback-policy", "failure-injection-report", "operations-owner", "incident-runbook", "deprovisioning-plan"]}
