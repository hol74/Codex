{
  "schemaVersion": 1,
  "modelId": "event-aware-financial-stress-v1",
  "modelFamily": "Causal event-aware rule-based financial stress signal",
  "taskRole": "financial-stress-signal",
  "lifecycleStatus": "research-challenger",
  "promotionTarget": "shadow-candidate",
  "frozenAt": "2026-07-14",
  "benchmarkScope": "nested-inner-validation-only",
  "inputs": {
    "VIX_MONTHLY_MAX": {"transform": "clip01((value - 18) / 42)"},
    "SPY_MONTHLY_MAX_DRAWDOWN": {"transform": "clip01(value / 25)"},
    "HYG_MONTHLY_MAX_DRAWDOWN": {"transform": "clip01(value / 15)"},
    "HY_OAS": {"transform": "clip01((value - 2) / 4)"},
    "SOFR_EFFR_MONTHLY_MAX": {"transform": "clip01(value / 200)"}
  },
  "baseScore": {
    "formula": "0.60 * max(vix, spyDrawdown, hygDrawdown, credit) + 0.40 * weightedMean",
    "weightedMean": {"vix": 0.30, "spyDrawdown": 0.25, "hygDrawdown": 0.25, "credit": 0.20}
  },
  "fundingOverlay": {
    "whenAvailable": "max(baseScore, 0.70 * funding + 0.30 * baseScore)",
    "whenMissing": "baseScore unchanged; no zero fill, backfill or fitted imputation"
  },
  "probability": "sigmoid(7 * (finalScore - 0.45))",
  "decisionThreshold": 0.5,
  "statePolicy": "stateless monthly signal; no backward smoothing and no future persistence",
  "labelPolicy": "Predictions are frozen before labels. Metrics use only months carrying at least one curated stress-v2 label; financial_stress is positive and other curated labels are comparison controls, never generic true negatives.",
  "outerOosPolicy": "Forbidden for selection, ranking, tuning or gate execution.",
