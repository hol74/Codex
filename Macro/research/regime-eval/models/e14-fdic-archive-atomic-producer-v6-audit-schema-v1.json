{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "https://macro-regime.local/schemas/e14-fdic-archive-atomic-producer-v6-audit-v1.json",
  "type": "object", "additionalProperties": false,
  "required": ["schemaVersion", "artifactType", "status", "hashes", "checks", "testExecution", "protocol", "decision"],
  "properties": {
    "schemaVersion": {"const": 1}, "artifactType": {"const": "E14FdicArchiveAtomicProducerV6Audit"}, "status": {"const": "FDIC_ARCHIVE_ATOMIC_PRODUCER_V6_IMPLEMENTED_INDEPENDENT_REVIEW_REQUIRED"},
    "hashes": {"type": "object", "additionalProperties": false, "required": ["implementationContract", "blockedReview", "plan", "producer", "tests", "runtimeValidationContract", "testReceipt", "testTranscript", "projectConfiguration"], "properties": {"implementationContract": {"$ref": "#/$defs/sha"}, "blockedReview": {"$ref": "#/$defs/sha"}, "plan": {"$ref": "#/$defs/sha"}, "producer": {"$ref": "#/$defs/sha"}, "tests": {"$ref": "#/$defs/sha"}, "runtimeValidationContract": {"$ref": "#/$defs/sha"}, "testReceipt": {"$ref": "#/$defs/sha"}, "testTranscript": {"$ref": "#/$defs/sha"}, "projectConfiguration": {"$ref": "#/$defs/sha"}}},
    "checks": {"type": "object", "additionalProperties": false, "required": ["stateRootCodePinned", "crossParentReplayRejected", "separateMonotonicAnchor", "ledgerDeletionDetected", "validPrefixRollbackDetected", "pendingCrashRecovered", "deadOwnerLockRecovered", "providerNetworkRejected"], "properties": {"stateRootCodePinned": {"const": true}, "crossParentReplayRejected": {"const": true}, "separateMonotonicAnchor": {"const": true}, "ledgerDeletionDetected": {"const": true}, "validPrefixRollbackDetected": {"const": true}, "pendingCrashRecovered": {"const": true}, "deadOwnerLockRecovered": {"const": true}, "providerNetworkRejected": {"const": true}}},
    "testExecution": {"type": "object", "additionalProperties": false, "required": ["receiptSha256", "transcriptSha256", "signerId", "externallyPinnedKeyVerified", "passed", "testsRun"], "properties": {"receiptSha256": {"$ref": "#/$defs/sha"}, "transcriptSha256": {"$ref": "#/$defs/sha"}, "signerId": {"const": "e14-v5-synthetic-test-runner-v1"}, "externallyPinnedKeyVerified": {"const": true}, "passed": {"const": true}, "testsRun": {"const": 5}}},
    "protocol": {"type": "object", "additionalProperties": false, "required": ["networkRequestsMade", "realEvidenceRowsCollected", "realBundlesPublished", "productionContractsPinned"], "properties": {"networkRequestsMade": {"const": 0}, "realEvidenceRowsCollected": {"const": 0}, "realBundlesPublished": {"const": 0}, "productionContractsPinned": {"const": 0}}},
    "decision": {"type": "object", "additionalProperties": false, "required": ["independentReviewAuthorized", "discoveryCatalogAuthorized", "executionGateAuthorized", "sourceAcquisitionAuthorized", "nextAllowedAction"], "properties": {"independentReviewAuthorized": {"const": true}, "discoveryCatalogAuthorized": {"const": false}, "executionGateAuthorized": {"const": false}, "sourceAcquisitionAuthorized": {"const": false}, "nextAllowedAction": {"type": "string", "minLength": 20}}}
  }, "$defs": {"sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"}}
}
