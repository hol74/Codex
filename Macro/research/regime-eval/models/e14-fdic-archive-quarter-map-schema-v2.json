{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://macro-regime.local/schemas/e14-fdic-archive-quarter-map-v2.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "artifactType", "mapId", "status", "sourceCatalog", "resolvedEntries", "confirmedAbsentEntries", "authorizationPolicy"],
  "properties": {
    "schemaVersion": {"const": 2},
    "artifactType": {"const": "E14FdicArchiveQuarterMap"},
    "mapId": {"const": "e14-fdic-archive-quarter-map-v2"},
    "status": {"const": "FDIC_ARCHIVE_QUARTER_MAP_PROVIDER_EVIDENCE_COMPLETE"},
    "sourceCatalog": {"$ref": "#/$defs/artifact"},
    "resolvedEntries": {"type": "array", "maxItems": 79, "items": {"$ref": "#/$defs/resolvedEntry"}},
    "confirmedAbsentEntries": {"type": "array", "maxItems": 79, "items": {"$ref": "#/$defs/absentEntry"}},
    "authorizationPolicy": {"$ref": "#/$defs/authorization"}
  },
  "$defs": {
    "artifact": {"type": "object", "additionalProperties": false, "required": ["fileName", "sha256", "sizeBytes"], "properties": {"fileName": {"type": "string", "minLength": 1}, "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "sizeBytes": {"type": "integer", "minimum": 1}}},
    "resolvedEntry": {"type": "object", "additionalProperties": false, "required": ["quarterId", "providerPrimaryUrl", "resolutionState", "archiveRecordId", "archiveUrl", "evidence"], "properties": {"quarterId": {"type": "string", "pattern": "^20[0-9]{2}Q[1-4]$"}, "providerPrimaryUrl": {"type": "string", "pattern": "^https://www\\.fdic\\.gov/.*$"}, "resolutionState": {"const": "resolved-provider-archive-record"}, "archiveRecordId": {"type": "string", "pattern": "^[0-9]+$"}, "archiveUrl": {"type": "string", "pattern": "^https://archive\\.fdic\\.gov/view/fdic/[0-9]+$"}, "evidence": {"$ref": "#/$defs/artifact"}}},
    "absentEntry": {"type": "object", "additionalProperties": false, "required": ["quarterId", "providerPrimaryUrl", "resolutionState", "absenceBasis", "evidence"], "properties": {"quarterId": {"type": "string", "pattern": "^20[0-9]{2}Q[1-4]$"}, "providerPrimaryUrl": {"type": "string", "pattern": "^https://www\\.fdic\\.gov/.*$"}, "resolutionState": {"const": "confirmed-absent-provider-primary"}, "absenceBasis": {"type": "string", "minLength": 20}, "evidence": {"$ref": "#/$defs/artifact"}}},
    "authorization": {"type": "object", "additionalProperties": false, "required": ["independentReviewRequired", "replacementExecutionGateAuthorized", "requestCatalogV3MaterializationAuthorized", "sourceAcquisitionAuthorized"], "properties": {"independentReviewRequired": {"const": true}, "replacementExecutionGateAuthorized": {"const": false}, "requestCatalogV3MaterializationAuthorized": {"const": false}, "sourceAcquisitionAuthorized": {"const": false}}}
  }
}
