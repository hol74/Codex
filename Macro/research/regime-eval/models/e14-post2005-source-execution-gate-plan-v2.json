{
  "schemaVersion": 2,
  "planId": "e14-post2005-source-execution-gate-plan-v2",
  "frozenAt": "2026-07-16",
  "manifestId": "e14-post2005-source-acquisition-manifest-v2",
  "requestCatalogId": "e14-post2005-source-acquisition-requests-v2",
  "timeoutSeconds": 30,
  "maximumProbeBytes": 65536,
  "credentialRequirements": [
    {
      "environmentVariable": "FRED_API_KEY",
      "appliesToSourceIds": ["fred-dgs2", "fred-dgs10", "fred-dcpf3m", "fred-dtb3"],
      "required": true,
      "secretMustNotBePersisted": true
    }
  ],
  "probes": [
    {"sourceId": "federal-reserve-h8-release-archive", "urlTemplate": "https://www.federalreserve.gov/releases/h8/default.htm", "expectedMarker": "Assets and Liabilities of Commercial Banks", "acceptedContentTypePrefixes": ["text/html"], "credentialEnvironmentVariable": null},
    {"sourceId": "fdic-qbp-archive", "urlTemplate": "https://www.fdic.gov/analysis/quarterly-banking-profile/", "expectedMarker": "Quarterly Banking Profile", "acceptedContentTypePrefixes": ["text/html"], "credentialEnvironmentVariable": null},
    {"sourceId": "fred-dgs2", "urlTemplate": "https://api.stlouisfed.org/fred/series?series_id=DGS2&api_key={FRED_API_KEY}&file_type=json", "expectedMarker": "DGS2", "acceptedContentTypePrefixes": ["application/json"], "credentialEnvironmentVariable": "FRED_API_KEY"},
    {"sourceId": "fred-dgs10", "urlTemplate": "https://api.stlouisfed.org/fred/series?series_id=DGS10&api_key={FRED_API_KEY}&file_type=json", "expectedMarker": "DGS10", "acceptedContentTypePrefixes": ["application/json"], "credentialEnvironmentVariable": "FRED_API_KEY"},
    {"sourceId": "federal-reserve-g5-release-archive", "urlTemplate": "https://www.federalreserve.gov/releases/g5/releaseDates.json", "expectedMarker": "releaseDate", "acceptedContentTypePrefixes": ["application/json", "text/json", "text/plain"], "credentialEnvironmentVariable": null},
    {"sourceId": "fred-dcpf3m", "urlTemplate": "https://api.stlouisfed.org/fred/series?series_id=DCPF3M&api_key={FRED_API_KEY}&file_type=json", "expectedMarker": "DCPF3M", "acceptedContentTypePrefixes": ["application/json"], "credentialEnvironmentVariable": "FRED_API_KEY"},
    {"sourceId": "fred-dtb3", "urlTemplate": "https://api.stlouisfed.org/fred/series?series_id=DTB3&api_key={FRED_API_KEY}&file_type=json", "expectedMarker": "DTB3", "acceptedContentTypePrefixes": ["application/json"], "credentialEnvironmentVariable": "FRED_API_KEY"}
  ],
  "networkPolicy": {
    "allowedHosts": ["www.federalreserve.gov", "www.fdic.gov", "api.stlouisfed.org"],
    "httpsOnly": true,
    "metadataOnly": true,
    "redirectsMustRemainOnAllowlist": true
  },
  "catalogPolicy": {
    "exactRequestTemplateCount": 11,
    "h10Forbidden": true,
    "g5ExpectedUniqueMonthCount": 240,
    "g5DuplicateOrCorrectionRequiresAdjudication": true,
    "fdicExpectedEligibleQuarterCount": 79,
    "fdicLastEligibleQuarter": "2025Q3",
    "fdicExcludedQuarter": "2025Q4",
    "fdicQuarterEndCannotSubstituteForPublicationDate": true
  },
  "authorizationPolicy": {
    "allCredentialsRequired": true,
    "allSevenProbesMustPass": true,
    "manifestAndCatalogHashesMustMatch": true,
    "catalogSemanticsMustMatch": true,
    "gateWritesSourceObservations": false,
    "gateWritesRawArtifacts": false,
    "successfulGateAuthorizesSeparateAcquisitionExecution": true,
    "featureTransformationAuthorized": false,
    "candidateGenerationAuthorized": false,
    "evaluationAuthorized": false,
    "outerOosAuthorized": false
  }
}
