{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://macro-regime.local/schemas/e14-fdic-archive-evidence-remediation-independent-review-v1.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion", "artifactType", "reviewId", "reviewerId",
    "reviewedAtUtc", "independenceDeclared", "contractSha256",
    "blockedReviewSha256", "remediationPlanSha256",
    "evidenceManifestSchemaSha256", "mapSchemaV3Sha256",
    "mapAuditSchemaV3Sha256", "remediationAuditSchemaSha256",
    "remediationAuditSha256", "implementationSha256", "testsSha256",
    "reviewSchemaSha256", "assessments", "decision", "blockingFindings",
    "rationale", "nextAllowedAction"
  ],
  "properties": {
    "schemaVersion": {"const": 1},
    "artifactType": {"const": "E14FdicArchiveEvidenceRemediationIndependentReview"},
    "reviewId": {"const": "e14-fdic-archive-evidence-remediation-independent-review-v1"},
    "reviewerId": {"type": "string", "minLength": 3},
    "reviewedAtUtc": {"type": "string", "minLength": 20},
    "independenceDeclared": {"const": true},
    "contractSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "blockedReviewSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "remediationPlanSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "evidenceManifestSchemaSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "mapSchemaV3Sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "mapAuditSchemaV3Sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "remediationAuditSchemaSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "remediationAuditSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "implementationSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "testsSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "reviewSchemaSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "assessments": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hashBindingsExact", "priorFindingsAddressed",
        "providerUrlAndRequestProvenanceBound", "rawBytesExistenceVerified",
        "exact79RosterEnforced", "quarterAndEvidenceUniquenessEnforced",
        "outcomeAndHashConsistencyEnforced", "sourceCatalogUrlsBound",
        "schemaAndSemanticValidationIntegrated", "auditCountsMapBound",
        "partialPublicationFailClosed", "negativeSelfTestsAdequate",
        "zeroNetworkConfirmed", "discoveryCatalogDesignAuthorized",
        "executionGateAuthorized", "catalogV3StillBlocked",
        "failClosedGuardsSupported"
      ],
      "properties": {
        "hashBindingsExact": {"type": "boolean"},
        "priorFindingsAddressed": {"type": "boolean"},
        "providerUrlAndRequestProvenanceBound": {"type": "boolean"},
        "rawBytesExistenceVerified": {"type": "boolean"},
        "exact79RosterEnforced": {"type": "boolean"},
        "quarterAndEvidenceUniquenessEnforced": {"type": "boolean"},
        "outcomeAndHashConsistencyEnforced": {"type": "boolean"},
        "sourceCatalogUrlsBound": {"type": "boolean"},
        "schemaAndSemanticValidationIntegrated": {"type": "boolean"},
        "auditCountsMapBound": {"type": "boolean"},
        "partialPublicationFailClosed": {"type": "boolean"},
        "negativeSelfTestsAdequate": {"type": "boolean"},
        "zeroNetworkConfirmed": {"type": "boolean"},
        "discoveryCatalogDesignAuthorized": {"type": "boolean"},
        "executionGateAuthorized": {"type": "boolean"},
        "catalogV3StillBlocked": {"type": "boolean"},
        "failClosedGuardsSupported": {"type": "boolean"}
      }
    },
    "decision": {"enum": ["accept", "needs_changes", "reject"]},
    "blockingFindings": {"type": "array", "items": {"type": "string", "minLength": 3}},
    "rationale": {"type": "string", "minLength": 20},
    "nextAllowedAction": {"type": "string", "minLength": 20}
  }
}
