    "thresholdSelection": {"type": "object"},
    "persistence": {"type": "object"},
    "availabilityPolicy": {"type": "object"},
    "evaluationPolicy": {"type": "object"},
    "fundingBoundarySensitivity": {"type": "object"},
    "identityTransitionPolicy": {"type": "object"},
    "generationPolicy": {"type": "object"},
    "vintageRiskPolicy": {"type": "object"},
    "constraints": {"type": "object"},
    "compositionPolicy": {"type": "object"},
    "authorizations": {"type": "object"}
  }
}
