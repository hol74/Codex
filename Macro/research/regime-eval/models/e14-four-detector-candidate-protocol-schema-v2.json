    "persistence",
    "availabilityPolicy",
    "evaluationPolicy",
    "fundingBoundarySensitivity",
    "identityTransitionPolicy",
    "generationPolicy",
    "vintageRiskPolicy",
    "constraints",
    "compositionPolicy",
    "authorizations"
