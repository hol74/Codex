{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://macro-regime.local/schemas/e14-four-detector-candidate-manifest-v1.json",
  "title": "E14 four-detector generated research candidate manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "artifactType",
    "immutable",
    "status",
    "generationId",
    "inputs",
    "candidateCount",
    "candidateCountByMechanism",
    "researchBoundary",
    "authorizations",
    "candidates",
    "implementation"
  ],
  "properties": {
    "schemaVersion": {"const": 1},
    "artifactType": {"const": "E14FourDetectorGeneratedCandidateManifest"},
    "immutable": {"const": true},
    "status": {"const": "GENERATED_NOT_FIT_NOT_EVALUATED_OUTER_OOS_CLOSED"},
    "generationId": {"type": "string", "pattern": "^[0-9a-f]{24}$"},
    "inputs": {"type": "object"},
    "candidateCount": {"const": 40},
    "candidateCountByMechanism": {
      "type": "object",
      "additionalProperties": false,
      "required": ["banking-credit", "broad-market-repricing", "cross-border-growth", "funding-liquidity"],
      "properties": {
        "banking-credit": {"const": 16},
        "broad-market-repricing": {"const": 16},
        "cross-border-growth": {"const": 4},
        "funding-liquidity": {"const": 4}
      }
    },
    "researchBoundary": {"const": "inner-development-only-current-history-snapshot"},
    "authorizations": {"type": "object"},
    "candidates": {
      "type": "array",
      "minItems": 40,
      "maxItems": 40,
      "items": {
        "type": "object",
        "required": [
          "candidateId",
          "mechanism",
          "detectorId",
          "lifecycleStatus",
          "profile",
          "featureBindings",
          "parameters"
        ]
      }
    },
    "implementation": {"type": "object"}
  }
}
