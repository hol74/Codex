{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://macro-regime.local/schemas/e14-financial-stress-taxonomy-v4.json",
  "title": "E14 mechanism-aware financial stress taxonomy v4",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "groundTruthId",
    "label",
    "geography",
    "frequency",
    "coverageFrom",
    "coverageTo",
    "derivedFrom",
    "foundation",
    "stateDefinitions",
    "monthResolutionPolicy",
    "mechanisms",
    "sources",
    "episodes",
    "hardNegativeEpisodes",
    "foundationEvidence",
    "coverage",
    "governance",
    "limitations"
  ],
  "properties": {
    "schemaVersion": {"const": 4},
    "groundTruthId": {"const": "us-financial-stress-mechanism-aware-v4"},
    "label": {"type": "string", "minLength": 1},
    "geography": {"type": "string", "minLength": 1},
    "frequency": {"const": "monthly"},
    "coverageFrom": {"type": "string", "format": "date"},
    "coverageTo": {"type": "string", "format": "date"},
    "derivedFrom": {"const": "us-financial-stress-tristate-v3"},
    "foundation": {"type": "object"},
    "stateDefinitions": {"type": "object"},
    "monthResolutionPolicy": {"type": "string", "minLength": 1},
    "mechanisms": {"type": "object", "minProperties": 4},
    "sources": {"type": "array"},
    "episodes": {"type": "array", "minItems": 1},
    "hardNegativeEpisodes": {"type": "array", "minItems": 1},
    "foundationEvidence": {"type": "array", "minItems": 12, "maxItems": 12},
    "coverage": {"type": "object"},
    "governance": {"type": "object"},
    "limitations": {"type": "array", "minItems": 1}
  }
}
