{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://macro-regime.local/schemas/e14-fdic-archive-producer-v3-bundle-audit-v1.json",
  "type": "object", "additionalProperties": false,
  "required": ["schemaVersion", "artifactType", "status", "contractSha256", "inputHashes", "manifestSha256", "mapSha256", "envelopeHashes", "envelopeCount", "postWriteVerificationPassed", "networkRequestsMade", "nextAllowedAction"],
  "properties": {
    "schemaVersion": {"const": 1},
    "artifactType": {"const": "E14FdicArchiveProducerV3BundleAudit"},
    "status": {"const": "FDIC_ARCHIVE_SIGNED_EVIDENCE_BUNDLE_COMPLETE"},
    "contractSha256": {"$ref": "#/$defs/sha"},
    "inputHashes": {"type": "object", "minProperties": 9, "maxProperties": 9, "additionalProperties": {"$ref": "#/$defs/sha"}},
    "manifestSha256": {"$ref": "#/$defs/sha"},
    "mapSha256": {"$ref": "#/$defs/sha"},
    "envelopeHashes": {"type": "object", "minProperties": 79, "maxProperties": 79, "additionalProperties": {"$ref": "#/$defs/sha"}},
    "envelopeCount": {"const": 79},
    "postWriteVerificationPassed": {"const": true},
    "networkRequestsMade": {"const": 0},
    "nextAllowedAction": {"type": "string", "minLength": 20}
  },
  "$defs": {"sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"}}
}
