{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://macro-regime.local/schemas/e14-episode-dossier-v1.json",
  "title": "E14 mechanism-specific episode dossier",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "dossierId",
    "hypothesisId",
    "mechanism",
    "proposedState",
    "firstMonth",
    "lastMonth",
    "boundaryRationale",
    "affirmativeOrderlyEvidence",
    "evidenceItems",
    "counterEvidence",
    "exclusionChecks",
    "adjudicationStatus",
    "reviewers"
  ],
  "properties": {
    "schemaVersion": {"const": 1},
    "dossierId": {"type": "string", "pattern": "^e14-dossier-[a-z0-9-]+$"},
    "hypothesisId": {"type": "string", "minLength": 1},
    "mechanism": {
      "enum": [
        "broad-market-repricing",
        "funding-liquidity",
        "banking-credit",
        "cross-border-growth"
      ]
    },
    "proposedState": {"enum": ["positive", "hard-negative"]},
    "firstMonth": {"type": "string", "format": "date"},
    "lastMonth": {"type": "string", "format": "date"},
    "boundaryRationale": {"type": "string", "minLength": 40},
    "affirmativeOrderlyEvidence": {"type": "boolean"},
    "evidenceItems": {
      "type": "array",
      "minItems": 2,
      "items": {"$ref": "#/$defs/evidenceItem"}
    },
    "counterEvidence": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/evidenceItem"}
    },
    "exclusionChecks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "outerOosUsed",
        "modelPredictionUsedAsLabel",
        "absenceTreatedAsEvidence",
        "methodologyRegimeRecorded",
        "nberOverlapReviewed"
      ],
      "properties": {
        "outerOosUsed": {"const": false},
        "modelPredictionUsedAsLabel": {"const": false},
        "absenceTreatedAsEvidence": {"const": false},
        "methodologyRegimeRecorded": {"const": true},
        "nberOverlapReviewed": {"const": true}
      }
    },
    "adjudicationStatus": {"enum": ["draft", "reviewed", "accepted", "rejected"]},
    "reviewers": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    }
  },
  "$defs": {
    "evidenceItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceId",
        "provider",
        "independenceGroup",
        "publishedAt",
        "role",
        "locator",
        "summary",
        "contentSha256"
      ],
      "properties": {
        "sourceId": {"type": "string", "minLength": 1},
        "provider": {"type": "string", "minLength": 1},
        "independenceGroup": {"type": "string", "minLength": 1},
        "publishedAt": {"type": "string", "format": "date"},
        "role": {
          "enum": [
            "official-narrative",
            "quantitative-observation",
            "boundary-corroboration",
            "counterevidence"
          ]
        },
        "locator": {"type": "string", "minLength": 1},
        "summary": {"type": "string", "minLength": 20},
        "contentSha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {"proposedState": {"const": "hard-negative"}},
        "required": ["proposedState"]
      },
      "then": {
        "properties": {"affirmativeOrderlyEvidence": {"const": true}}
      },
      "else": {
        "properties": {"affirmativeOrderlyEvidence": {"const": false}}
      }
    },
    {
      "if": {
        "properties": {"adjudicationStatus": {"const": "accepted"}},
        "required": ["adjudicationStatus"]
      },
      "then": {
        "properties": {"reviewers": {"minItems": 2}}
      }
    }
  ]
}
