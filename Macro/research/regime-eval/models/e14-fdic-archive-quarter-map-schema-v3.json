{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://macro-regime.local/schemas/e14-fdic-archive-quarter-map-v3.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "artifactType", "mapId", "status", "sourceCatalog", "evidenceManifest", "entries", "authorizationPolicy"],
  "properties": {
    "schemaVersion": {"const": 3},
    "artifactType": {"const": "E14FdicArchiveQuarterMap"},
    "mapId": {"const": "e14-fdic-archive-quarter-map-v3"},
    "status": {"const": "FDIC_ARCHIVE_QUARTER_MAP_PROVIDER_EVIDENCE_COMPLETE"},
    "sourceCatalog": {"$ref": "#/$defs/artifact"},
    "evidenceManifest": {"$ref": "#/$defs/artifact"},
    "entries": {"type": "array", "minItems": 79, "maxItems": 79, "items": {"$ref": "#/$defs/entry"}},
    "authorizationPolicy": {"$ref": "#/$defs/authorization"}
  },
  "$defs": {
    "artifact": {"type": "object", "additionalProperties": false, "required": ["fileName", "sha256", "sizeBytes"], "properties": {"fileName": {"type": "string", "minLength": 1}, "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "sizeBytes": {"type": "integer", "minimum": 1}}},
    "entry": {"type": "object", "additionalProperties": false, "required": ["quarterId", "providerPrimaryUrl", "outcome", "evidenceId", "evidenceSha256"], "properties": {"quarterId": {"type": "string", "pattern": "^20[0-9]{2}Q[1-4]$"}, "providerPrimaryUrl": {"type": "string", "pattern": "^https://www\\.fdic\\.gov/.*$"}, "outcome": {"enum": ["resolved-provider-archive-record", "confirmed-absent-provider-primary"]}, "evidenceId": {"type": "string", "minLength": 3}, "evidenceSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "archiveRecordId": {"type": "string", "pattern": "^[0-9]+$"}, "archiveUrl": {"type": "string", "pattern": "^https://archive\\.fdic\\.gov/view/fdic/[0-9]+$"}, "absenceBasis": {"type": "string", "minLength": 20}}},
    "authorization": {"type": "object", "additionalProperties": false, "required": ["independentReviewRequired", "executionGateAuthorized", "requestCatalogV3MaterializationAuthorized", "sourceAcquisitionAuthorized"], "properties": {"independentReviewRequired": {"const": true}, "executionGateAuthorized": {"const": false}, "requestCatalogV3MaterializationAuthorized": {"const": false}, "sourceAcquisitionAuthorized": {"const": false}}}
  }
}
