    "acquisitionRunId": {"type": "string"}, "runNonce": {"type": "string"}, "collectorReceiptSha256": {"$ref": "#/$defs/sha"}, "inputHashes": {"type": "object", "minProperties": 10, "maxProperties": 10}, "manifestSha256": {"$ref": "#/$defs/sha"}, "mapSha256": {"$ref": "#/$defs/sha"}, "envelopeHashes": {"type": "object", "minProperties": 79, "maxProperties": 79},
