<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <header>
        <nav class="topbar">
            <a asp-area="" asp-page="/Index">MacroRegime</a>
            <a asp-area="" asp-page="/CompareRuns">Compare runs</a>
            <a asp-area="" asp-page="/ImportDiagnostics">Import diagnostics</a>
            <span>Local dashboard</span>
        </nav>
    </header>
    <div class="shell">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
