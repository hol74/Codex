@model Finance.Application.Ledger.TransactionFormPage

@{
    var heading = ViewData["TransactionHeading"]?.ToString() ?? "Nuova transazione";
    var formAction = ViewData["FormAction"]?.ToString() ?? "Create";
    ViewData["Title"] = heading;
}

<section class="page-heading">
    <div>
        <p class="eyebrow">Ledger</p>
        <h1>@heading</h1>
    </div>
</section>

<section class="data-panel">
    <form asp-action="@formAction" method="post">
        @await Html.PartialAsync("_Form", Model)
    </form>
</section>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
