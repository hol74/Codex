@model Finance.Application.Ledger.TransactionFormPage

@{
    ViewData["Title"] = "Modifica transazione";
}

<section class="page-heading">
    <div>
        <p class="eyebrow">Ledger</p>
        <h1>Modifica transazione</h1>
    </div>
</section>

<section class="data-panel">
    <form asp-action="Edit" asp-route-id="@Model.Transaction.Id" method="post">
        @await Html.PartialAsync("_Form", Model)
    </form>
</section>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
