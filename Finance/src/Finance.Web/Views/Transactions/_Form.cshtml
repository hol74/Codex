@model Finance.Application.Ledger.TransactionFormPage
@using System.Globalization
@using Finance.Domain.Enums

@functions {
    private static string DecimalValue(decimal value) => value.ToString("0.########", CultureInfo.InvariantCulture);
}

@{
    var fixedType = ViewData["FixedTransactionType"] is TransactionType transactionType ? transactionType : (TransactionType?)null;
    var isCashMovement = fixedType is TransactionType.Deposit or TransactionType.Withdrawal;
    var isTrade = fixedType is TransactionType.Buy or TransactionType.Sell;
    var cancelAction = ViewData["CancelAction"]?.ToString() ?? "Index";
}

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<input asp-for="Transaction.Id" type="hidden" />
<input name="__Invariant" type="hidden" value="Transaction.Quantity" />
<input name="__Invariant" type="hidden" value="Transaction.Price" />
<input name="__Invariant" type="hidden" value="Transaction.GrossAmount" />
<input name="__Invariant" type="hidden" value="Transaction.FxRateToBase" />
<input name="__Invariant" type="hidden" value="Transaction.Fees" />
<input name="__Invariant" type="hidden" value="Transaction.Taxes" />

<div class="form-grid">
    <div class="mb-3">
        <label asp-for="Transaction.TradeDate" class="form-label">Data trade</label>
        <input asp-for="Transaction.TradeDate" type="date" class="form-control" />
        <span asp-validation-for="Transaction.TradeDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Transaction.SettlementDate" class="form-label">Data settlement</label>
        <input asp-for="Transaction.SettlementDate" type="date" class="form-control" />
        <span asp-validation-for="Transaction.SettlementDate" class="text-danger"></span>
    </div>

    @if (fixedType is not null)
    {
        <input type="hidden" name="Transaction.Type" value="@fixedType" />
        <div class="mb-3">
            <label class="form-label">Tipo</label>
            <div class="readonly-field">@fixedType</div>
        </div>
    }
    else
    {
        <div class="mb-3">
            <label asp-for="Transaction.Type" class="form-label">Tipo</label>
            <select asp-for="Transaction.Type" class="form-select" asp-items="@(new Microsoft.AspNetCore.Mvc.Rendering.SelectList(Model.Options.TransactionTypes, "Value", "Label"))"></select>
            <span asp-validation-for="Transaction.Type" class="text-danger"></span>
        </div>
    }

    <div class="mb-3">
        <label asp-for="Transaction.PortfolioId" class="form-label">Portafoglio</label>
        <select asp-for="Transaction.PortfolioId" class="form-select" asp-items="@(new Microsoft.AspNetCore.Mvc.Rendering.SelectList(Model.Options.Portfolios, "Id", "Label"))"></select>
        <span asp-validation-for="Transaction.PortfolioId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Transaction.CashAccountId" class="form-label">Conto cash</label>
        <select asp-for="Transaction.CashAccountId" class="form-select" asp-items="@(new Microsoft.AspNetCore.Mvc.Rendering.SelectList(Model.Options.CashAccounts, "Id", "Label"))"></select>
        <span asp-validation-for="Transaction.CashAccountId" class="text-danger"></span>
    </div>

    @if (!isCashMovement)
    {
        <div class="mb-3">
            <label asp-for="Transaction.SecuritiesAccountId" class="form-label">Conto titoli</label>
            <select asp-for="Transaction.SecuritiesAccountId" class="form-select" asp-items="@(new Microsoft.AspNetCore.Mvc.Rendering.SelectList(Model.Options.SecuritiesAccounts, "Id", "Label"))">
                <option value="">Non applicabile</option>
            </select>
            <span asp-validation-for="Transaction.SecuritiesAccountId" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Transaction.InstrumentId" class="form-label">Strumento</label>
            <select asp-for="Transaction.InstrumentId" class="form-select" asp-items="@(new Microsoft.AspNetCore.Mvc.Rendering.SelectList(Model.Options.Instruments, "Id", "Label"))">
                <option value="">Non applicabile</option>
            </select>
            <span asp-validation-for="Transaction.InstrumentId" class="text-danger"></span>
        </div>
    }
    else
    {
        <input type="hidden" name="Transaction.SecuritiesAccountId" value="" />
        <input type="hidden" name="Transaction.InstrumentId" value="" />
    }

    <div class="mb-3">
        <label asp-for="Transaction.PriceCurrencyId" class="form-label">Valuta prezzo/importo</label>
        <select asp-for="Transaction.PriceCurrencyId" class="form-select" asp-items="@(new Microsoft.AspNetCore.Mvc.Rendering.SelectList(Model.Options.Currencies, "Id", "Label"))"></select>
        <span asp-validation-for="Transaction.PriceCurrencyId" class="text-danger"></span>
    </div>

    @if (!isCashMovement)
    {
        <div class="mb-3">
            <label asp-for="Transaction.Quantity" class="form-label">Quantita</label>
            <input id="Transaction_Quantity" name="Transaction.Quantity" type="text" inputmode="decimal" class="form-control" value="@DecimalValue(Model.Transaction.Quantity)" />
            <span asp-validation-for="Transaction.Quantity" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Transaction.Price" class="form-label">Prezzo</label>
            <input id="Transaction_Price" name="Transaction.Price" type="text" inputmode="decimal" class="form-control" value="@DecimalValue(Model.Transaction.Price)" />
            <span asp-validation-for="Transaction.Price" class="text-danger"></span>
        </div>
    }
    else
    {
        <input id="Transaction_Quantity" name="Transaction.Quantity" type="hidden" value="0" />
        <input id="Transaction_Price" name="Transaction.Price" type="hidden" value="1" />
    }

    <div class="mb-3">
        <label asp-for="Transaction.GrossAmount" class="form-label">@(isCashMovement ? "Importo" : "Importo lordo")</label>
        <input id="Transaction_GrossAmount" name="Transaction.GrossAmount" type="text" inputmode="decimal" class="form-control" value="@DecimalValue(Model.Transaction.GrossAmount)" />
        <span asp-validation-for="Transaction.GrossAmount" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Transaction.FxRateToBase" class="form-label">FX verso valuta base</label>
        <input id="Transaction_FxRateToBase" name="Transaction.FxRateToBase" type="text" inputmode="decimal" class="form-control" value="@DecimalValue(Model.Transaction.FxRateToBase)" />
        <span asp-validation-for="Transaction.FxRateToBase" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Transaction.Fees" class="form-label">Commissioni</label>
        <input id="Transaction_Fees" name="Transaction.Fees" type="text" inputmode="decimal" class="form-control" value="@DecimalValue(Model.Transaction.Fees)" />
        <span asp-validation-for="Transaction.Fees" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Transaction.Taxes" class="form-label">Tasse</label>
        <input id="Transaction_Taxes" name="Transaction.Taxes" type="text" inputmode="decimal" class="form-control" value="@DecimalValue(Model.Transaction.Taxes)" />
        <span asp-validation-for="Transaction.Taxes" class="text-danger"></span>
    </div>
</div>

<div class="mb-3">
    <label asp-for="Transaction.Notes" class="form-label">Note</label>
    <textarea asp-for="Transaction.Notes" class="form-control" rows="3"></textarea>
    <span asp-validation-for="Transaction.Notes" class="text-danger"></span>
</div>

<div class="form-actions">
    <button type="submit" class="btn btn-primary">Salva</button>
    <a class="btn btn-outline-secondary" asp-action="@cancelAction">Annulla</a>
</div>
